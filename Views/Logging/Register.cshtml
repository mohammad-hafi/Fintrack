@using fintrack.DTOs
@model UserRegister

@{
    ViewData["Title"] = "FinTrack";
}
<div class="bg-white text-slate-900 antialiased">

  <div class="min-h-screen grid lg:grid-cols-5">

    <!-- Illustration panel -->
    <div class="hidden lg:flex lg:col-span-2 relative bg-slate-900 flex-col justify-between p-12 overflow-hidden">
      <div class="absolute -top-24 -left-24 w-80 h-80 rounded-full bg-indigo-500/20 blur-3xl"></div>
      <div class="absolute bottom-0 right-0 w-72 h-72 rounded-full bg-emerald-500/20 blur-3xl"></div>

      <a href="/" class="relative flex items-center gap-2">
        <span class="w-8 h-8 rounded-lg bg-emerald-500 flex items-center justify-center">
          <svg class="w-5 h-5 text-white" viewBox="0 0 24 24" fill="none"><rect x="2" y="6" width="20" height="13" rx="2.5" stroke="white" stroke-width="1.8"/><path d="M2 10H22" stroke="white" stroke-width="1.8"/><circle cx="17" cy="14" r="1.4" fill="white"/></svg>
        </span>
        <span class="font-display text-lg font-bold text-white">FinTrack</span>
      </a>

      <div class="relative">
        <div class="space-y-4">
          <div class="flex items-start gap-3 bg-white/5 border border-white/10 rounded-2xl p-4">
            <span class="w-9 h-9 rounded-full bg-emerald-500/20 flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-emerald-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path d="M9 12l2 2 4-4"/></svg>
            </span>
            <div>
              <p class="text-white text-sm font-semibold">Free to open</p>
              <p class="text-slate-400 text-xs mt-0.5">No minimum balance, no monthly fees.</p>
            </div>
          </div>
          <div class="flex items-start gap-3 bg-white/5 border border-white/10 rounded-2xl p-4">
            <span class="w-9 h-9 rounded-full bg-emerald-500/20 flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-emerald-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path d="M9 12l2 2 4-4"/></svg>
            </span>
            <div>
              <p class="text-white text-sm font-semibold">Ready in two minutes</p>
              <p class="text-slate-400 text-xs mt-0.5">Verify your email and start sending money.</p>
            </div>
          </div>
          <div class="flex items-start gap-3 bg-white/5 border border-white/10 rounded-2xl p-4">
            <span class="w-9 h-9 rounded-full bg-emerald-500/20 flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-emerald-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path d="M9 12l2 2 4-4"/></svg>
            </span>
            <div>
              <p class="text-white text-sm font-semibold">Protected from day one</p>
              <p class="text-slate-400 text-xs mt-0.5">Encrypted balances and two-factor sign-in.</p>
            </div>
          </div>
        </div>

        <h2 class="font-display text-2xl font-bold text-white mt-10 max-w-xs">Join 180,000+ people managing money on FinTrack.</h2>
      </div>

      <p class="relative text-slate-500 text-xs">© 2026 FinTrack Wallet Management</p>
    </div>

    <!-- Form panel -->
    <div class="lg:col-span-3 flex items-center justify-center px-6 py-12 sm:py-16">
      <div class="w-full max-w-sm">
        <a href="/" class="lg:hidden flex items-center gap-2 mb-10 justify-center">
          <span class="w-8 h-8 rounded-lg bg-emerald-600 flex items-center justify-center">
            <svg class="w-5 h-5 text-white" viewBox="0 0 24 24" fill="none"><rect x="2" y="6" width="20" height="13" rx="2.5" stroke="white" stroke-width="1.8"/><path d="M2 10H22" stroke="white" stroke-width="1.8"/><circle cx="17" cy="14" r="1.4" fill="white"/></svg>
          </span>
          <span class="font-display text-lg font-bold text-slate-900">FinTrack</span>
        </a>

        <h1 class="font-display text-3xl font-bold text-slate-900">Create your account</h1>
        <p class="text-slate-600 mt-2">It only takes a couple of minutes.</p>

        <form asp-controller="Session" asp-action="Register" method="post" class="mt-8 space-y-5">
          <div>
            <label for="fullname" class="block text-sm font-medium text-slate-700 mb-1.5">Full name</label>
            <input type="text" id="fullname" name="name" placeholder="Sarah Chen"
              class="w-full px-4 py-3 rounded-xl border border-slate-300 text-sm placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 transition-shadow" />
          </div>

          <div>
            <label for="email" class="block text-sm font-medium text-slate-700 mb-1.5">Email address</label>
            <input asp-for="Email" type="email" id="email" name="email" placeholder="you@example.com"
              class="w-full px-4 py-3 rounded-xl border border-slate-300 text-sm placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 transition-shadow" />
          </div>
<span asp-validation-for="Email"></span>
          <div>
            <label for="password" class="block text-sm font-medium text-slate-700 mb-1.5">Password</label>
            <input asp-for="Password" type="password" id="password" name="password" placeholder="Create a password"
              class="w-full px-4 py-3 rounded-xl border border-slate-300 text-sm placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 transition-shadow" />
          </div>
<span asp-validation-for="Password"></span>
          <div class="flex items-start gap-2.5">
            <input type="checkbox" id="terms" name="terms" class="w-4 h-4 mt-0.5 rounded border-slate-300 text-emerald-600 focus:ring-emerald-500" />
            <label for="terms" class="text-sm text-slate-600">I agree to the <a href="#" class="font-medium text-emerald-600 hover:text-emerald-700">Terms of Service</a> and <a href="#" class="font-medium text-emerald-600 hover:text-emerald-700">Privacy Policy</a>.</label>
          </div>

          <button type="submit" class="w-full bg-emerald-600 hover:bg-emerald-700 text-white font-semibold text-sm py-3.5 rounded-xl shadow-lg shadow-emerald-600/25 transition-colors">
            Register
          </button>
        </form>

        <p class="text-center text-sm text-slate-600 mt-8">
          Already have an account?
          <a href="/login" class="font-semibold text-emerald-600 hover:text-emerald-700">Log in</a>
        </p>
      </div>
    </div>
  </div>

</div>