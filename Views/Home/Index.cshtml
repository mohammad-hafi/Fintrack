@{
    ViewData["Title"] = "FinTrack";
}

<body class="bg-white text-slate-900 antialiased">

  <!-- Navbar -->
  <header class="sticky top-0 z-50 bg-white/80 backdrop-blur-md border-b border-slate-200">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 h-16 flex items-center justify-between">
      <a asp-controller="Home" asp-action="Index" class="flex items-center gap-2">
        <span class="w-8 h-8 rounded-lg bg-emerald-600 flex items-center justify-center">
          <svg class="w-5 h-5 text-white" viewBox="0 0 24 24" fill="none"><rect x="2" y="6" width="20" height="13" rx="2.5" stroke="white" stroke-width="1.8"/><path d="M2 10H22" stroke="white" stroke-width="1.8"/><circle cx="17" cy="14" r="1.4" fill="white"/></svg>
        </span>
        <span class="font-display text-lg font-bold text-slate-900">FinTrack</span>
      </a>

      <nav class="hidden md:flex items-center gap-8 text-sm font-medium text-slate-600">
        <a href="#features" class="hover:text-slate-900 transition-colors">Features</a>
        <a href="#security" class="hover:text-slate-900 transition-colors">Security</a>
        <a href="#stats" class="hover:text-slate-900 transition-colors">Why FinTrack</a>
      </nav>

      <div class="hidden md:flex items-center gap-3">
        <a asp-controller="Logging" asp-action="Login" class="text-sm font-semibold text-slate-700 hover:text-slate-900 px-4 py-2 transition-colors">Log in</a>
        <a asp-controller="Logging" asp-action="Register" class="text-sm font-semibold text-white bg-emerald-600 hover:bg-emerald-700 px-4 py-2.5 rounded-lg shadow-sm shadow-emerald-600/20 transition-colors">Open free account</a>
      </div>

      <button id="menuBtn" class="md:hidden p-2 text-slate-700" onclick="document.getElementById('mobileMenu').classList.toggle('hidden')">
        <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M3 6h18M3 12h18M3 18h18"/></svg>
      </button>
    </div>
    <div id="mobileMenu" class="hidden md:hidden border-t border-slate-200 bg-white px-6 py-4 space-y-3">
      <a class="block text-slate-600 font-medium">Features</a>
      <a class="block text-slate-600 font-medium">Security</a>
      <a class="block text-slate-600 font-medium">Why FinTrack</a>
      <div class="pt-3 flex flex-col gap-2">
        <a asp-controller="Logging" asp-action="Login" class="text-center font-semibold text-slate-700 border border-slate-300 rounded-lg py-2.5">Log in</a>
        <a asp-controller="Logging" asp-action="Register" class="text-center font-semibold text-white bg-emerald-600 rounded-lg py-2.5">Open free account</a>
      </div>
    </div>
  </header>

  <!-- Hero -->
  <section class="relative overflow-hidden bg-gradient-to-b from-slate-50 to-white">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 pt-16 pb-24 lg:pt-24 lg:pb-32 grid lg:grid-cols-2 gap-16 items-center">
      <div>
        <span class="inline-flex items-center gap-2 text-xs font-semibold uppercase tracking-widest text-emerald-700 bg-emerald-50 border border-emerald-100 rounded-full px-3 py-1.5">
          <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
          Digital wallet platform
        </span>
        <h1 class="font-display text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight text-slate-900 mt-6 leading-[1.1]">
          Send, hold, and track every dollar — safely.
        </h1>
        <p class="text-lg text-slate-600 mt-6 max-w-md leading-relaxed">
          FinTrack gives you one secure wallet for deposits, transfers, and everyday spending — with the clarity of a bank statement and the speed of a tap.
        </p>
        <div class="mt-8 flex flex-wrap items-center gap-4">
          <a asp-controller="Logging" asp-action="Register" class="inline-flex items-center justify-center font-semibold text-white bg-emerald-600 hover:bg-emerald-700 px-6 py-3.5 rounded-xl shadow-lg shadow-emerald-600/25 transition-colors">
            Open a free account
          </a>
          <a asp-controller="Logging" asp-action="Login" class="inline-flex items-center justify-center font-semibold text-slate-700 hover:text-slate-900 px-6 py-3.5 rounded-xl border border-slate-300 hover:border-slate-400 transition-colors">
            Log in
          </a>
        </div>
        <div class="mt-10 flex items-center gap-6 text-sm text-slate-500">
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 text-emerald-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2l8 4v6c0 5-3.5 8-8 10-4.5-2-8-5-8-10V6l8-4z"/></svg>
            256-bit encryption
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 text-emerald-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 12l2 2 4-4"/><circle cx="12" cy="12" r="9"/></svg>
            Two-factor authentication
          </div>
        </div>
      </div>

      <div class="relative flex justify-center lg:justify-end">
        <div class="absolute w-72 h-72 bg-emerald-200/40 rounded-full blur-3xl -top-8 -right-8"></div>
        <div class="relative w-full max-w-sm rotate-[-4deg] hover:rotate-0 transition-transform duration-500">
          <div class="relative aspect-[1.6/1] rounded-3xl bg-gradient-to-br from-emerald-400 via-blue-600 to-indigo-700 p-7 shadow-2xl shadow-indigo-900/30 overflow-hidden">
            <div class="absolute -right-10 -top-10 w-40 h-40 rounded-full bg-white/10"></div>
            <div class="absolute -right-2 bottom-6 w-24 h-24 rounded-full bg-white/10"></div>
            <div class="relative flex items-center justify-between">
              <span class="font-display text-white font-semibold tracking-wide">FinTrack</span>
              <svg class="w-9 h-6 text-white/90" viewBox="0 0 32 24" fill="none"><rect x="0.5" y="0.5" width="31" height="23" rx="4" stroke="currentColor"/><line x1="0.5" y1="9" x2="31.5" y2="9" stroke="currentColor"/></svg>
            </div>
            <div class="relative mt-9">
              <p class="text-white/70 text-xs font-medium tracking-widest uppercase">Available balance</p>
              <p class="font-display text-white text-3xl sm:text-4xl font-semibold mt-1">$24,318.92</p>
            </div>
            <div class="relative mt-7 flex items-center justify-between">
              <p class="font-mono text-white/80 text-sm tracking-widest">•••• •••• •••• 4821</p>
              <p class="text-white/70 text-xs tracking-wide">SARAH CHEN</p>
            </div>
          </div>
          <div class="absolute -bottom-6 -left-6 bg-white rounded-2xl shadow-xl shadow-slate-900/10 border border-slate-100 px-4 py-3 flex items-center gap-3">
            <span class="w-9 h-9 rounded-full bg-emerald-50 flex items-center justify-center">
              <svg class="w-5 h-5 text-emerald-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 19V5M5 12l7-7 7 7"/></svg>
            </span>
            <div>
              <p class="text-xs text-slate-500">Transfer received</p>
              <p class="text-sm font-semibold text-slate-900 font-mono">+$1,250.00</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section id="features" class="py-20 lg:py-28 bg-white">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="max-w-2xl">
        <h2 class="font-display text-3xl sm:text-4xl font-bold text-slate-900">Everything your wallet needs to do, in one place</h2>
        <p class="text-slate-600 mt-4 text-lg">No spreadsheets, no guesswork — just a clear view of money coming in and going out.</p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6 mt-14">
        <div class="group p-6 rounded-2xl border border-slate-200 hover:border-emerald-200 hover:shadow-lg hover:shadow-slate-900/5 transition-all">
          <span class="w-11 h-11 rounded-xl bg-emerald-50 flex items-center justify-center">
            <svg class="w-5 h-5 text-emerald-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 2 4 14h7l-1 8 9-12h-7z"/></svg>
          </span>
          <h3 class="font-display font-semibold text-slate-900 mt-5">Instant transfers</h3>
          <p class="text-sm text-slate-600 mt-2 leading-relaxed">Send money to any FinTrack user in seconds, with live status from sent to settled.</p>
        </div>
        <div class="group p-6 rounded-2xl border border-slate-200 hover:border-blue-200 hover:shadow-lg hover:shadow-slate-900/5 transition-all">
          <span class="w-11 h-11 rounded-xl bg-blue-50 flex items-center justify-center">
            <svg class="w-5 h-5 text-blue-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="6" width="20" height="13" rx="2.5"/><path d="M2 10h20"/></svg>
          </span>
          <h3 class="font-display font-semibold text-slate-900 mt-5">One wallet, full control</h3>
          <p class="text-sm text-slate-600 mt-2 leading-relaxed">Deposit, hold, and spend from a single balance that updates the moment money moves.</p>
        </div>
        <div class="group p-6 rounded-2xl border border-slate-200 hover:border-indigo-200 hover:shadow-lg hover:shadow-slate-900/5 transition-all">
          <span class="w-11 h-11 rounded-xl bg-indigo-50 flex items-center justify-center">
            <svg class="w-5 h-5 text-indigo-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2l8 4v6c0 5-3.5 8-8 10-4.5-2-8-5-8-10V6l8-4z"/></svg>
          </span>
          <h3 class="font-display font-semibold text-slate-900 mt-5">Bank-grade security</h3>
          <p class="text-sm text-slate-600 mt-2 leading-relaxed">Encrypted in transit and at rest, with two-factor sign-in on every device.</p>
        </div>
        <div class="group p-6 rounded-2xl border border-slate-200 hover:border-emerald-200 hover:shadow-lg hover:shadow-slate-900/5 transition-all">
          <span class="w-11 h-11 rounded-xl bg-emerald-50 flex items-center justify-center">
            <svg class="w-5 h-5 text-emerald-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 17l5-5 4 4 8-8"/><path d="M21 21H3V3"/></svg>
          </span>
          <h3 class="font-display font-semibold text-slate-900 mt-5">Real-time activity</h3>
          <p class="text-sm text-slate-600 mt-2 leading-relaxed">Every deposit and transfer logged instantly, searchable in your full transaction history.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Security band -->
  <section id="security" class="py-16 bg-slate-50 border-y border-slate-200">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 grid lg:grid-cols-2 gap-12 items-center">
      <div>
        <h2 class="font-display text-2xl sm:text-3xl font-bold text-slate-900">Built like a bank, not a spreadsheet</h2>
        <p class="text-slate-600 mt-4 leading-relaxed">Every account is protected by layered security designed for financial data — not bolted on after the fact.</p>
        <ul class="mt-6 space-y-3 text-sm text-slate-700">
          <li class="flex items-start gap-3"><svg class="w-5 h-5 text-emerald-600 mt-0.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path d="M9 12l2 2 4-4"/></svg>End-to-end encrypted balances and transfers</li>
          <li class="flex items-start gap-3"><svg class="w-5 h-5 text-emerald-600 mt-0.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path d="M9 12l2 2 4-4"/></svg>Real-time fraud monitoring on every transaction</li>
          <li class="flex items-start gap-3"><svg class="w-5 h-5 text-emerald-600 mt-0.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path d="M9 12l2 2 4-4"/></svg>Account-level activity alerts, sent instantly</li>
        </ul>
      </div>
      <div class="bg-white rounded-2xl border border-slate-200 p-8 shadow-sm">
        <div class="flex items-center gap-3 pb-5 border-b border-slate-100">
          <span class="w-10 h-10 rounded-full bg-emerald-50 flex items-center justify-center">
            <svg class="w-5 h-5 text-emerald-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2l8 4v6c0 5-3.5 8-8 10-4.5-2-8-5-8-10V6l8-4z"/></svg>
          </span>
          <div>
            <p class="font-semibold text-slate-900 text-sm">Account protection</p>
            <p class="text-xs text-slate-500">Status: Active</p>
          </div>
        </div>
        <div class="mt-5 space-y-4">
          <div class="flex items-center justify-between text-sm">
            <span class="text-slate-600">Two-factor authentication</span>
            <span class="text-emerald-700 font-semibold bg-emerald-50 px-2.5 py-1 rounded-full text-xs">Enabled</span>
          </div>
          <div class="flex items-center justify-between text-sm">
            <span class="text-slate-600">Device verification</span>
            <span class="text-emerald-700 font-semibold bg-emerald-50 px-2.5 py-1 rounded-full text-xs">Enabled</span>
          </div>
          <div class="flex items-center justify-between text-sm">
            <span class="text-slate-600">Login alerts</span>
            <span class="text-emerald-700 font-semibold bg-emerald-50 px-2.5 py-1 rounded-full text-xs">Enabled</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section id="stats" class="py-20 lg:py-24 bg-slate-900">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="text-center max-w-xl mx-auto">
        <h2 class="font-display text-3xl font-bold text-white">Trusted with money that matters</h2>
        <p class="text-slate-400 mt-3">Numbers from the FinTrack network, updated continuously.</p>
      </div>
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-8 mt-14">
        <div class="text-center">
          <p class="font-display text-4xl font-bold text-white">$2.4B+</p>
          <p class="text-sm text-slate-400 mt-2">Processed securely</p>
        </div>
        <div class="text-center">
          <p class="font-display text-4xl font-bold text-white">180K+</p>
          <p class="text-sm text-slate-400 mt-2">Active wallets</p>
        </div>
        <div class="text-center">
          <p class="font-display text-4xl font-bold text-white">99.98%</p>
          <p class="text-sm text-slate-400 mt-2">Platform uptime</p>
        </div>
        <div class="text-center">
          <p class="font-display text-4xl font-bold text-white">&lt;2s</p>
          <p class="text-sm text-slate-400 mt-2">Average transfer time</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 lg:py-24 bg-white">
    <div class="max-w-5xl mx-auto px-6 lg:px-8">
      <div class="rounded-3xl bg-gradient-to-br from-emerald-500 via-blue-600 to-indigo-700 px-8 sm:px-14 py-14 text-center relative overflow-hidden">
        <div class="absolute -top-10 -left-10 w-48 h-48 rounded-full bg-white/10"></div>
        <div class="absolute -bottom-10 -right-10 w-56 h-56 rounded-full bg-white/10"></div>
        <h2 class="relative font-display text-3xl sm:text-4xl font-bold text-white">Ready to take control of your money?</h2>
        <p class="relative text-white/80 mt-4 max-w-md mx-auto">Open a FinTrack wallet in under two minutes. No paperwork, no branch visits.</p>
        <a href="register.html" class="relative inline-flex mt-8 items-center justify-center font-semibold text-emerald-700 bg-white hover:bg-slate-50 px-7 py-3.5 rounded-xl shadow-lg transition-colors">
          Create your free account
        </a>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="bg-slate-900 border-t border-slate-800">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 py-16 grid sm:grid-cols-2 lg:grid-cols-5 gap-10">
      <div class="lg:col-span-2">
        <div class="flex items-center gap-2">
          <span class="w-8 h-8 rounded-lg bg-emerald-600 flex items-center justify-center">
            <svg class="w-5 h-5 text-white" viewBox="0 0 24 24" fill="none"><rect x="2" y="6" width="20" height="13" rx="2.5" stroke="white" stroke-width="1.8"/><path d="M2 10H22" stroke="white" stroke-width="1.8"/><circle cx="17" cy="14" r="1.4" fill="white"/></svg>
          </span>
          <span class="font-display text-lg font-bold text-white">FinTrack</span>
        </div>
        <p class="text-slate-400 text-sm mt-4 max-w-xs">Secure digital wallet &amp; payment management for individuals who want clarity over their money.</p>
      </div>
      <div>
        <p class="text-white text-sm font-semibold">Product</p>
        <ul class="mt-4 space-y-2.5 text-sm text-slate-400">
          <li><a href="#features" class="hover:text-white transition-colors">Features</a></li>
          <li><a href="#security" class="hover:text-white transition-colors">Security</a></li>
          <li><a href="dashboard.html" class="hover:text-white transition-colors">Dashboard</a></li>
        </ul>
      </div>
      <div>
        <p class="text-white text-sm font-semibold">Company</p>
        <ul class="mt-4 space-y-2.5 text-sm text-slate-400">
          <li><a href="#" class="hover:text-white transition-colors">About</a></li>
          <li><a href="#" class="hover:text-white transition-colors">Careers</a></li>
          <li><a href="#" class="hover:text-white transition-colors">Contact</a></li>
        </ul>
      </div>
      <div>
        <p class="text-white text-sm font-semibold">Legal</p>
        <ul class="mt-4 space-y-2.5 text-sm text-slate-400">
          <li><a href="#" class="hover:text-white transition-colors">Privacy</a></li>
          <li><a href="#" class="hover:text-white transition-colors">Terms</a></li>
          <li><a href="#" class="hover:text-white transition-colors">Compliance</a></li>
        </ul>
      </div>
    </div>
    <div class="border-t border-slate-800 max-w-7xl mx-auto px-6 lg:px-8 py-6 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-slate-500 text-xs">© 2026 FinTrack Wallet Management. All rights reserved.</p>
      <div class="flex items-center gap-4 text-slate-500">
        <svg class="w-5 h-5 hover:text-white transition-colors" viewBox="0 0 24 24" fill="currentColor"><path d="M22 5.9c-.7.3-1.5.6-2.3.7.8-.5 1.5-1.3 1.8-2.3-.8.5-1.7.8-2.6 1-.7-.8-1.8-1.3-3-1.3-2.2 0-4 1.8-4 4 0 .3 0 .6.1.9C8.3 8.6 5.6 7.1 3.7 4.7c-.3.5-.5 1.2-.5 1.8 0 1.4.7 2.6 1.8 3.3-.7 0-1.3-.2-1.8-.5 0 1.9 1.4 3.6 3.3 4-.4.1-.7.1-1.1.1-.3 0-.5 0-.8-.1.5 1.6 2 2.8 3.8 2.8-1.4 1.1-3.2 1.8-5.1 1.8-.3 0-.7 0-1-.1C4.1 19 6.3 19.7 8.7 19.7c8 0 12.4-6.7 12.4-12.4v-.6c.8-.6 1.5-1.3 2-2.1-.8.3-1.5.5-2.1.6z"/></svg>
        <svg class="w-5 h-5 hover:text-white transition-colors" viewBox="0 0 24 24" fill="currentColor"><path d="M19 3H5a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2V5a2 2 0 00-2-2zM8.3 18.3H5.7V9.8h2.6v8.5zM7 8.7c-.9 0-1.5-.6-1.5-1.4S6.1 5.9 7 5.9s1.5.6 1.5 1.4-.6 1.4-1.5 1.4zm11.3 9.6h-2.6v-4.4c0-1.1-.4-1.8-1.4-1.8-.7 0-1.2.5-1.4 1-.1.2-.1.5-.1.8v4.4h-2.6s0-7.2 0-7.9h2.6v1.1c.3-.5 1-1.3 2.4-1.3 1.7 0 3 1.1 3 3.6v4.5z"/></svg>
      </div>
    </div>
  </footer>

</body>
