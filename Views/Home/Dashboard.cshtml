@using fintrack.ViewModels
@model fintrack.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "FinTrack";
}
<div class="bg-slate-50 text-slate-900 antialiased">

  <!-- App Navbar -->
  

  <main class="max-w-7xl mx-auto px-6 lg:px-8 py-8 space-y-8">

    <div>
      <h1 class="font-display text-2xl font-bold text-slate-900">Welcome back, @Model.User?.Name</h1>
    </div>

    <!-- Wallet overview -->
    <div class="grid lg:grid-cols-3 gap-6 w-full">
      <!-- Balance card (signature wallet card) -->
      <div class="relative rounded-3xl bg-gradient-to-br from-emerald-400 via-blue-600 to-indigo-700 p-7 shadow-xl shadow-indigo-900/15 overflow-hidden">
        <div class="absolute -right-10 -top-10 w-44 h-44 rounded-full bg-white/10"></div>
        <div class="absolute -right-2 bottom-6 w-24 h-24 rounded-full bg-white/10"></div>
        <div class="relative flex items-center justify-between">
          <span class="font-display text-white font-semibold tracking-wide">FinTrack</span>
          <svg class="w-9 h-6 text-white/90" viewBox="0 0 32 24" fill="none"><rect x="0.5" y="0.5" width="31" height="23" rx="4" stroke="currentColor"/><line x1="0.5" y1="9" x2="31.5" y2="9" stroke="currentColor"/></svg>
        </div>
        <p class="relative text-white/70 text-xs font-medium tracking-widest uppercase mt-8">Current balance</p>
        <p class="relative font-display text-white text-4xl font-semibold mt-1">$@Model.User?.Balance</p>
        <div class="relative mt-7 flex items-center justify-between">
          <p class="font-mono text-white/80 text-sm tracking-widest">•••• •••• •••• 4821</p>
          <p class="text-white/70 text-xs tracking-wide">@Model.User?.Name</p>
        </div>
      </div>
    </div>

    <!-- Quick actions -->
    <div>
      <h2 class="font-display text-lg font-semibold text-slate-900 mb-4">Quick actions</h2>
      <div class="grid sm:grid-cols-3 gap-5">
        <a asp-controller="Wallet" asp-action="Deposit" class="group bg-white rounded-2xl border border-slate-200 hover:border-emerald-300 hover:shadow-lg hover:shadow-slate-900/5 p-6 flex items-center gap-4 transition-all">
          <span class="w-12 h-12 rounded-xl bg-emerald-50 flex items-center justify-center shrink-0 group-hover:bg-emerald-100 transition-colors">
            <svg class="w-5.5 h-5.5 text-emerald-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12h14"/></svg>
          </span>
          <div>
            <p class="font-semibold text-slate-900">Deposit money</p>
            <p class="text-sm text-slate-500 mt-0.5">Add funds to your wallet</p>
          </div>
        </a>
        <a href="transfer.html" class="group bg-white rounded-2xl border border-slate-200 hover:border-blue-300 hover:shadow-lg hover:shadow-slate-900/5 p-6 flex items-center gap-4 transition-all">
          <span class="w-12 h-12 rounded-xl bg-blue-50 flex items-center justify-center shrink-0 group-hover:bg-blue-100 transition-colors">
            <svg class="w-5.5 h-5.5 text-blue-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 2 4 14h7l-1 8 9-12h-7z"/></svg>
          </span>
          <div>
            <p class="font-semibold text-slate-900">Transfer money</p>
            <p class="text-sm text-slate-500 mt-0.5">Send to another wallet</p>
          </div>
        </a>
        <a asp-controller="Home" asp-action="Transaction" class="group bg-white rounded-2xl border border-slate-200 hover:border-indigo-300 hover:shadow-lg hover:shadow-slate-900/5 p-6 flex items-center gap-4 transition-all">
          <span class="w-12 h-12 rounded-xl bg-indigo-50 flex items-center justify-center shrink-0 group-hover:bg-indigo-100 transition-colors">
            <svg class="w-5.5 h-5.5 text-indigo-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="16" rx="2"/><path d="M3 9h18M8 14h2M8 17h6"/></svg>
          </span>
          <div>
            <p class="font-semibold text-slate-900">View transactions</p>
            <p class="text-sm text-slate-500 mt-0.5">See your full history</p>
          </div>
        </a>
      </div>
    </div>
  </main>

</div>