@using fintrack.ViewModels
@model DashboardViewModel
<div class="bg-slate-50 text-slate-900 antialiased">

  <!-- App Navbar -->


  <main class="max-w-7xl mx-auto px-6 lg:px-8 py-8 space-y-6">

    <div>
      <h1 class="font-display text-2xl font-bold text-slate-900">Transaction history</h1>
      <p class="text-slate-500 text-sm mt-1">A complete record of every deposit and transfer on your wallet.</p>
    </div>

    <!-- Table -->
    <div class="bg-white rounded-2xl border border-slate-200 overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="text-left text-slate-500 border-b border-slate-100 bg-slate-50/60">
              <th class="px-6 py-3 font-medium">Date</th>
              <th class="px-6 py-3 font-medium">Sender</th>
              <th class="px-6 py-3 font-medium">Receiver</th>
              <th class="px-6 py-3 font-medium">Amount</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            @foreach (var tx in Model.Transactions)
            {
              <tr class="hover:bg-slate-50/60 transition-colors">
                <td class="px-6 py-4 text-slate-600">@tx.Date.ToString("MMM d, yyyy")</td>
                <td class="px-6 py-4 font-medium text-slate-900">@tx.Sender?.Name</td>
                <td class="px-6 py-4 text-slate-600">@tx.Receiver?.Name</td>
                <td class="px-6 py-4 font-mono text-slate-900">@String.Format("{0:C}", tx.Amount)</td>
              </tr>
            }
          </tbody>
        </table>
      </div>
    </div>

  </main>

</div>