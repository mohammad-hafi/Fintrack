@model fintrack.ViewModels.WithdrawViewModel
@{
    ViewData["Title"] = "FinTrack";
}
<div class="bg-slate-50 text-slate-900 antialiased">
  <main class="max-w-5xl mx-auto px-6 lg:px-8 py-8">
    <a asp-controller="Home" asp-action="Dashboard" class="inline-flex items-center gap-1.5 text-sm font-medium text-slate-500 hover:text-slate-700 mb-4">
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 19l-7-7 7-7"/></svg>
      Back to dashboard
    </a>

    <div class="mb-8">
      <h1 class="font-display text-2xl font-bold text-slate-900">Withdraw money</h1>
      <p class="text-slate-500 text-sm mt-1">Move funds from your FinTrack wallet safely and quickly.</p>
    </div>

    <div class="grid lg:grid-cols-5 gap-6">
      <div class="lg:col-span-3 bg-white rounded-2xl border border-slate-200 p-7">
        <h2 class="font-display font-semibold text-slate-900 mb-1">Enter amount</h2>
        <p class="text-sm text-slate-500 mb-6">Withdrawals are recorded in your transaction history.</p>

        <form method="post" class="space-y-6">
          <div>
            <label asp-for="Amount" class="block text-sm font-medium text-slate-700 mb-1.5">Amount</label>
            <div class="relative">
              <span class="absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 font-display font-semibold">$</span>
              <input type="text" asp-for="Amount" placeholder="0.00"
                class="w-full pl-9 pr-4 py-4 rounded-xl border border-slate-300 text-2xl font-display font-semibold text-slate-900 placeholder:text-slate-300 focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-amber-500 transition-shadow" />
            </div>
            <span asp-validation-for="Amount" class="mt-2 block text-sm text-red-600"></span>
          </div>

          <div class="flex items-start gap-3 bg-amber-50/60 border border-amber-100 rounded-xl p-4">
            <svg class="w-5 h-5 text-amber-600 mt-0.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2l8 4v6c0 5-3.5 8-8 10-4.5-2-8-5-8-10V6l8-4z"/></svg>
            <p class="text-sm text-amber-800">Withdrawals are logged immediately and cannot exceed your available balance.</p>
          </div>

          <button type="submit" class="w-full bg-amber-600 hover:bg-amber-700 text-white font-semibold text-sm py-3.5 rounded-xl shadow-lg shadow-amber-600/25 transition-colors">
            Withdraw funds
          </button>
        </form>
      </div>
    </div>
  </main>
</div>