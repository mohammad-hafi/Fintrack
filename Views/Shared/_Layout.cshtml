@{
    var userName = Context.Session.GetString("UserName");
}
@if(TempData["Error"] != null)
{
 <div class="bg-red-100 text-red-700 p-3 rounded-lg mb-4">
        @TempData["Error"]
    </div>
}
@if(TempData["Error"] != null)
{
 <div class="bg-red-100 text-red-700 p-3 rounded-lg mb-4">
        @TempData["Success"]
    </div>
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - fintrack</title>
    <script type="importmap"></script>
<script src="https://cdn.tailwindcss.com"></script>
</head>
<body>
    <div>
@if (Context.Session.GetInt32("UserId") != null)
{
  <header class="sticky top-0 z-50 bg-white border-b border-slate-200">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 h-16 flex items-center justify-between">
      <div class="flex items-center gap-8">
        <a asp-controller="Home" asp-action="Dashboard" class="flex items-center gap-2">
          <span class="w-8 h-8 rounded-lg bg-emerald-600 flex items-center justify-center">
            <svg class="w-5 h-5 text-white" viewBox="0 0 24 24" fill="none"><rect x="2" y="6" width="20" height="13" rx="2.5" stroke="white" stroke-width="1.8"/><path d="M2 10H22" stroke="white" stroke-width="1.8"/><circle cx="17" cy="14" r="1.4" fill="white"/></svg>
          </span>
          <span class="font-display text-lg font-bold text-slate-900 hidden sm:inline">FinTrack</span>
        </a>
        <nav class="hidden md:flex items-center gap-1 text-sm font-medium">
          <a asp-controller="Home" asp-action="Dashboard" class="px-3.5 py-2 rounded-lg bg-emerald-50 text-emerald-700 font-semibold">Dashboard</a>
          <a asp-controller="Home" asp-action="Transaction" class="px-3.5 py-2 rounded-lg text-slate-600 hover:bg-slate-50 hover:text-slate-900 transition-colors">Transactions</a>
          <a asp-controller="Home" asp-action="Transfer" class="px-3.5 py-2 rounded-lg text-slate-600 hover:bg-slate-50 hover:text-slate-900 transition-colors">Transfer</a>
        </nav>
      </div>
      <div class="flex items-center gap-4">
        <div class="flex items-center gap-2.5 pl-3 border-l border-slate-200">
          <span class="text-sm font-medium text-slate-700 hidden sm:inline">@userName</span>
        </div>
        <a asp-controller="Session" asp-action="Logout" class="text-sm font-medium text-slate-500 hover:text-red-600 transition-colors">Logout</a>
      </div>
    </div>
  </header>
}
        <main role="main" class=" w-full">
            @RenderBody()
        </main>
    </div>
</body>
</html>
